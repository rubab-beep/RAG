# .env.example — Copy this to .env and fill in your values
# cp .env.example .env

# Required for OpenAI embeddings + LLM
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Set to True to use free local embeddings (no API key needed)
# Also update config.py: USE_LOCAL_EMBEDDINGS = True
# USE_LOCAL_EMBEDDINGS=False
